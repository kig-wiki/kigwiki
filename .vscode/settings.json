{
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "markdown",
    "mdx"
  ],
  "javascript.validate.enable": true,
  "[markdown]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[mdx]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "files.associations": {
    "*.md": "mdx"
  }
} 